--
--  HOW TO USE THIS FILE:
--  ---------------------
--  1. Save this file as: hrm_professional.sql
--  2. Run in terminal: mysql -u root -p < hrm_professional.sql
--  3. Or in MySQL: source /path/to/hrm_professional.sql
--  4. Default database created: hrm_pro
--  5. Default user: root (configure in .env)
